# =============================================================================
# Template des variables d'environnement — EvoluSkills
# =============================================================================
# Copier ce fichier vers .env.local et remplir les valeurs :
#   cp .env.example .env.local
#
# ⚠️  Ne JAMAIS commiter .env ni .env.local (déjà dans .gitignore).
# =============================================================================

# ---- Frontend (Vite) — publiques, embarquées dans le bundle JS ----
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_URL="https://<project-id>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY=""

# ---- Backend / Scripts admin — SECRET, ne JAMAIS exposer au frontend ----
# Utilisée uniquement par les scripts scripts/upsert-formation.ts et
# scripts/upload-image.ts. Non préfixée VITE_ → Vite ne l'embarque pas.
# À régénérer régulièrement : Supabase → Settings → API → Reset service_role.
SUPABASE_SERVICE_ROLE_KEY=""
